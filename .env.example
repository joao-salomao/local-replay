# Replay Local — environment variables
#
# Copy this file to `.env` and adjust as needed. Bun automatically loads `.env`
# at startup, so any value set here is picked up by `bun run` and the container.
# Every variable has a sensible default; you only need to set what you want to change.
# `.env` is gitignored (it may hold deployment specifics) — `.env.example` is the tracked template.

# ─── Storage ──────────────────────────────────────────────────────────────────
# Directory holding config.json (with the auto-generated password), certs/ and clips/.
# Persisted across restarts. In Docker it's a mounted volume (see docker-compose.yml).
DATA_DIR=data

# ─── Logging ──────────────────────────────────────────────────────────────────
# Verbosity of the server logs (stdout/stderr and the /control live log viewer).
# One of: debug | info | warn | error | silent. Unknown values fall back to info.
LOG_LEVEL=info

# ─── LAN mode (default) ───────────────────────────────────────────────────────
# Self-signed HTTPS on the local network. This is the default when BEHIND_PROXY is unset.
# HTTPS port — the entry point of the system in LAN mode.
HTTPS_PORT=8443
# HTTP port — only issues a 301 redirect to the HTTPS port in LAN mode.
HTTP_PORT=8080
# The machine's LAN IP, baked into the self-signed cert (SAN) and printed in the boot URL/QR.
# start.sh detects and injects this automatically; set it manually only if running outside start.sh.
HOST_LAN_IP=

# ─── Internet mode (behind a reverse proxy) ───────────────────────────────────
# Set BEHIND_PROXY to 1/true/yes to serve plain HTTP (a front proxy like Caddy/nginx/Cloudflare
# terminates TLS) and trust the X-Forwarded-For header for the client IP. See the README
# section "Rodando na internet (atrás de um proxy)". Leave unset for LAN mode.
BEHIND_PROXY=
# The public address the proxy serves (e.g. https://replay.example.com). Used for the boot
# URL and QR code in proxy mode. Required in proxy mode; falls back to http://localhost:PORT if unset.
PUBLIC_URL=
# The plain-HTTP port the app listens on for the proxy to forward to (proxy mode only).
PORT=8080
