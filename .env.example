# Replay Local — environment variables
#
# Copy this file to `.env` and adjust as needed. Bun automatically loads `.env`
# at startup, so any value set here is picked up by `bun run` and the container.
# Every variable EXCEPT PASSWORD has a sensible default — PASSWORD is REQUIRED (the server
# refuses to boot without it); you only need to set what else you want to change.
# `.env` is gitignored (it may hold deployment specifics) — `.env.example` is the tracked template.

# ─── Access ───────────────────────────────────────────────────────────────────
# REQUIRED. The shared password players type to log in. A starter default is set below so a fresh
# clone runs out of the box — change it to your own (especially before exposing the app publicly).
PASSWORD=replay

# REQUIRED. HMAC key used to sign session cookies. Keep it STABLE across restarts (changing it logs
# everyone out). The value below is a WORKING EXAMPLE — generate your own before exposing the app to
# the internet (it's committed to the repo, so it's public): openssl rand -hex 32
SESSION_SECRET=736f162ca9a9aac399758eedf7cd2e5a13229b5c13bbbce8885c883b7e1f2fde

# ─── Storage ──────────────────────────────────────────────────────────────────
# Directory holding certs/, clips/, and config.json — the last is where the live-adjustable settings
# (clip duration, audio source, capture res/fps, buffer margin, upload timeout) are saved when you
# change them on /control. Persisted across restarts. In Docker it's a mounted volume (see
# docker-compose.yml).
DATA_DIR=data

# ─── Logging ──────────────────────────────────────────────────────────────────
# Verbosity of the server logs (stdout/stderr and the /control live log viewer).
# One of: debug | info | warn | error | silent. Unknown values fall back to info.
LOG_LEVEL=info

# ─── Clips & output ───────────────────────────────────────────────────────────
# NOTE: the settings the control page manages live — clip duration, combined audio, capture res/fps,
# buffer margin, upload timeout — are deliberately NOT here. They default in code and persist to
# <DATA_DIR>/config.json when you change them on /control. Only the variables below are env-settable.
#
# Maximum clip length the /control selector / the API will accept.
CLIP_DURATION_MAX_SECONDS=60
# Floor for each camera's buffer cycle length (seconds). The actual cycle is
# max(BUFFER_CYCLE_MIN_SECONDS, clip duration + buffer margin).
BUFFER_CYCLE_MIN_SECONDS=30
# Target resolution/framerate the final normalized clips are conformed to.
TARGET_HEIGHT=1080
TARGET_FPS=60
# Days to keep clips before automatic cleanup runs. Empty = keep everything forever.
RETENTION_DAYS=

# ─── LAN mode (default) ───────────────────────────────────────────────────────
# Self-signed HTTPS on the local network. This is the default when BEHIND_PROXY is unset.
# HTTPS port — the entry point of the system in LAN mode.
HTTPS_PORT=8443
# HTTP port — only issues a 301 redirect to the HTTPS port in LAN mode.
HTTP_PORT=8080
# The machine's LAN IP, baked into the self-signed cert (SAN) and printed in the boot URL/QR.
# start.sh detects and injects this automatically; set it manually only if running outside start.sh.
HOST_LAN_IP=

# ─── Internet mode (behind a reverse proxy) ───────────────────────────────────
# Set BEHIND_PROXY to 1/true/yes to serve plain HTTP (a front proxy like Caddy/nginx/Cloudflare
# terminates TLS) and trust the X-Forwarded-For header for the client IP. See the README
# section "Running on the Internet (Behind a Proxy)". Leave unset for LAN mode.
BEHIND_PROXY=
# The public address the proxy serves (e.g. https://replay.example.com). Used for the boot
# URL and QR code in proxy mode. Required in proxy mode; falls back to http://localhost:PORT if unset.
PUBLIC_URL=
# The plain-HTTP port the app listens on for the proxy to forward to (proxy mode only).
PORT=8080
